# PROD environment variables (fill and copy to `.env.prod`)
#
# Used by:
# - ./scripts/supabase_link.sh prod
# - ./scripts/supabase_set_secrets.sh prod
# - ./scripts/supabase_seed_remote.sh prod
# - ./scripts/rates_sync_once.sh prod

SUPABASE_PROJECT_REF=replace_me
SUPABASE_URL=https://YOUR_PROD_PROJECT.supabase.co
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

OPENEXCHANGE_APP_ID=replace_me
COINGECKO_API_KEY=replace_me
# Legacy fallback alias (optional):
# COINGEKO_API_KEY=replace_me
RATES_SYNC_SECRET=replace_me
RATES_SYNC_MAX_CRYPTO=100
RATES_SYNC_MAX_FIAT=100
# Optional override. For Pro keys you may set:
# COINGECKO_BASE_URL=https://pro-api.coingecko.com/api/v3

# Recommended: keep disabled in prod until payments integration is implemented.
UPDATE_PLAN_ENABLED=false
UPDATE_PLAN_ALLOWLIST_EMAILS=

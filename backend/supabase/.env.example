# Edge Function secrets (do NOT commit your real .env)
#
# Push secrets to Supabase with:
#   ./scripts/supabase_set_secrets.sh

# Rates providers
OPENEXCHANGE_APP_ID=replace_me
COINGEKO_API_KEY=replace_me

# Protect rates_sync (verify_jwt is disabled for this function)
RATES_SYNC_SECRET=replace_me

# Optional: cap how many crypto assets are priced per run (CoinGecko request limits).
# Default: 250
RATES_SYNC_MAX_CRYPTO=250

# Dev/testing only: allows the client stub "upgrade" to flip plan via update_plan.
# Recommended: keep false in prod until payments integration is implemented.
UPDATE_PLAN_ENABLED=false

# Optional allowlist for update_plan (comma-separated emails).
# Example: UPDATE_PLAN_ALLOWLIST_EMAILS=you@example.com,other@example.com
UPDATE_PLAN_ALLOWLIST_EMAILS=

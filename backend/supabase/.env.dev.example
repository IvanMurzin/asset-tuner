# DEV environment variables (fill and copy to `.env.dev`)
#
# Used by:
# - ./scripts/supabase_link.sh dev
# - ./scripts/supabase_set_secrets.sh dev
# - ./scripts/supabase_seed_remote.sh dev
# - ./scripts/rates_sync_once.sh dev

# Identifies the Supabase project to link (Dashboard -> Project Settings -> General -> Reference ID)
SUPABASE_PROJECT_REF=replace_me

# Project API URL (Dashboard -> Project Settings -> API -> Project URL)
SUPABASE_URL=https://YOUR_DEV_PROJECT.supabase.co

# Database connection string (Dashboard -> Project Settings -> Database -> Connection string)
# Use the "URI" format suitable for psql, includes password.
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Edge Function secrets (pushed via `supabase secrets set`)
OPENEXCHANGE_APP_ID=replace_me
COINGEKO_API_KEY=replace_me
RATES_SYNC_SECRET=replace_me
RATES_SYNC_MAX_CRYPTO=250

# Dev/testing only (keep false in prod)
UPDATE_PLAN_ENABLED=true
UPDATE_PLAN_ALLOWLIST_EMAILS=you@example.com
